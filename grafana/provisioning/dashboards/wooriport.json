{
  "title": "Wooriport API 모니터링",
  "uid": "wooriport-api",
  "timezone": "Asia/Seoul",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "총 요청 수 (RPS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wooriport\",uri!~\"/actuator.*\"}[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 2,
      "title": "에러율 (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wooriport\",uri!~\"/actuator.*\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"wooriport\",uri!~\"/actuator.*\"}[1m])) * 100",
          "legendFormat": "5xx"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wooriport\",uri!~\"/actuator.*\",status=~\"4..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"wooriport\",uri!~\"/actuator.*\"}[1m])) * 100",
          "legendFormat": "4xx"
        }
      ]
    },
    {
      "id": 3,
      "title": "평균 응답 시간 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_sum{application=\"wooriport\",uri!~\"/actuator.*\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"wooriport\",uri!~\"/actuator.*\"}[1m])) * 1000",
          "legendFormat": "avg latency"
        }
      ]
    },
    {
      "id": 4,
      "title": "URI별 평균 응답 시간 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_server_requests_seconds_sum{application=\"wooriport\",uri!~\"/actuator.*\"}[1m]) / rate(http_server_requests_seconds_count{application=\"wooriport\",uri!~\"/actuator.*\"}[1m]) * 1000",
          "legendFormat": "{{uri}} [{{method}}]"
        }
      ]
    },
    {
      "id": 5,
      "title": "FastAPI 응답 시간 P95 (엔드포인트별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{job=\"fastapi\", handler!~\"/metrics|/health\"}[5m])))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "FastAPI 에러율 (4xx · 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "min": 0, "max": 1 },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"fastapi\", status=~\"[45]..\"}[5m])) / sum(rate(http_requests_total{job=\"fastapi\"}[5m]))",
          "legendFormat": "4xx+5xx rate"
        }
      ]
    },
    {
      "id": 10,
      "title": "💸 핀테크 - 이체 (confirm-all)",
      "type": "row",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "이체 성공률 (%)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 27, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"wooriport\",uri=\"/api/v1/transfer-plans/confirm-all\",status=~\"2..\"}[1h])) / sum(rate(http_server_requests_seconds_count{application=\"wooriport\",uri=\"/api/v1/transfer-plans/confirm-all\"}[1h])) * 100",
          "legendFormat": "성공률"
        }
      ]
    },
    {
      "id": 12,
      "title": "이체 실패 건수 (최근 1시간)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 27, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_requests_seconds_count{application=\"wooriport\",uri=\"/api/v1/transfer-plans/confirm-all\",status=~\"[45]..\"}[1h]))",
          "legendFormat": "실패 건수"
        }
      ]
    },
    {
      "id": 13,
      "title": "이체 성공/실패 추이 (5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 27, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_requests_seconds_count{application=\"wooriport\",uri=\"/api/v1/transfer-plans/confirm-all\",status=~\"2..\"}[5m]))",
          "legendFormat": "성공"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_requests_seconds_count{application=\"wooriport\",uri=\"/api/v1/transfer-plans/confirm-all\",status=~\"[45]..\"}[5m]))",
          "legendFormat": "실패"
        }
      ]
    }
  ],
  "schemaVersion": 38
}
