# 이 파일을 terraform.tfvars 로 복사한 뒤 값을 채우세요.
# (terraform.tfvars 는 .gitignore 에 포함되어 커밋되지 않습니다)

project = "myapp"

# SSM으로 접속하므로 키페어는 선택사항. 백업용으로 쓰려면 기존 키페어 이름 입력.
# key_name = "my-keypair"

# --- RDS PostgreSQL (기본값으로도 동작. 운영 전환 시 아래 조정) ---
# enable_rds = true                        # RDS on/off 스위치 (기본 on). 끄려면 false
# rds_instance_class      = "db.t3.micro"  # 운영은 db.t3.medium 이상
# rds_multi_az            = true           # 운영 권장 (기본 false=비용 절감)
# rds_deletion_protection = true           # 운영 권장
# rds_db_name             = "appdb"
# rds_username            = "appuser"
# 비밀번호는 자동 생성됨 → 확인: terraform output -raw rds_password

# --- Spring Batch (추후 예정 / 분리 시 켜기) ---
# enable_batch     = true
# batch_start_cron = "cron(50 1 * * ? *)"  # 매일 01:50 KST 시작
# batch_stop_cron  = "cron(0 3 * * ? *)"   # 매일 03:00 KST 중지
